/*
Problem: Sum of First N Natural Numbers using Recursion

Approach:
- If N becomes 0, return 0.
- Otherwise, return the current number plus the sum of the first N-1 numbers.
- This follows the recursive relation:
  Sum(N) = N + Sum(N - 1)

Time Complexity: O(N)
Space Complexity: O(N)
(Recursion stack)
*/

class Solution {
public:
    int NnumbersSum(int N) {
        if (N == 0) {
            return 0;
        }

        return N + NnumbersSum(N - 1);
    }
};

