/*
Problem: Valid Palindrome (LeetCode 125)

Approach:
- Create a new string containing only lowercase alphanumeric characters.
- Use recursion to compare characters from both ends.
- If a mismatch is found, immediately return false.
- If all corresponding characters match, return true.

Time Complexity: O(N)
Space Complexity: O(N)
(Cleaned string + recursion stack)
*/

class Solution {
public:
    bool pali(string &s, int left, int right) {
        if (left >= right) {
            return true;
        }

        if (s[left] != s[right]) {
            return false;
        }

        return pali(s, left + 1, right - 1);
    }

    bool isPalindrome(string s) {
        string str = "";

        for (char ch : s) {
            if (isalnum(ch)) {
                str += tolower(ch);
            }
        }

        return pali(str, 0, str.size() - 1);
    }
};

