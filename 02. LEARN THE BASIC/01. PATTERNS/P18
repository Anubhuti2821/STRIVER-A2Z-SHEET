/*
Problem: Pattern 18

Pattern (N = 5):
E
D E
C D E
B C D E
A B C D E

Approach:
- For each row, determine the starting character.
- The starting character is 'A' + (n - i).
- Print characters from the starting character up to 'A' + (n - 1).

Time Complexity: O(N²)
Space Complexity: O(1)
*/

class Solution {
public:
    void pattern18(int n) {
        for (int i = 1; i <= n; i++) {
            char ch = 'A' + (n - i);

            for (int j = 1; j <= i; j++) {
                cout << ch << " ";
                ch++;
            }

            cout << endl;
        }
    }
};

/*
Possible Optimization:
- No optimization is possible.
- Every character in the pattern must be printed exactly once,
  so O(N²) time is optimal.
- Space complexity is already O(1).
*/
