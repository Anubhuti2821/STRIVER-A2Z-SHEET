/*
Problem: Largest Element in an Array

Description:
Given an array of integers, return the largest element present in the array.
*/

class Solution {
public:
    int largestElement(vector<int>& nums) {
        int largest = nums[0];

        for (int i = 1; i < nums.size(); i++) {
            if (nums[i] > largest) {
                largest = nums[i];
            }
        }

        return largest;
    }
};

