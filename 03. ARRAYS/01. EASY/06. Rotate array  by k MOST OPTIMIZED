/*
Problem: Left Rotate Array by K Places

Description:
Given an integer array nums and an integer k, rotate the array to the left by k positions.
If k is greater than the size of the array, rotate by k % n positions.

Approach:
1. Compute k = k % n to handle cases where k > n.
2. Reverse the first k elements.
3. Reverse the remaining n - k elements.
4. Reverse the entire array.
5. This results in the array being left rotated by k positions.

Time Complexity: O(n)
Space Complexity: O(1)
*/

class Solution {
public:
    void rotateArray(vector<int>& nums, int k) {
        int n = nums.size();

        if (n == 0)
            return;

        k %= n;

        reverse(nums.begin(), nums.begin() + k);
        reverse(nums.begin() + k, nums.end());
        reverse(nums.begin(), nums.end());
    }
};

