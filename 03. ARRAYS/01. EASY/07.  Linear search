/*
Problem: Linear Search

Approach:
Traverse the array from left to right.
If the current element matches the target, return its index.
If the target is not found after traversing the entire array, return -1.
*/

class Solution {
public:
    int linearSearch(vector<int>& nums, int target) {
        int n = nums.size();

        for(int i = 0; i < n; i++) {
            if(nums[i] == target) {
                return i;
            }
        }

        return -1;
    }
};

/*
Time Complexity: O(n)
Space Complexity: O(1)

Possible Optimization:
Linear Search is optimal for unsorted arrays. If the array is sorted and multiple searches are required, Binary Search can reduce the search time to O(log n).
*/
