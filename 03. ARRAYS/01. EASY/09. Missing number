/*
Problem: Missing Number

Approach:
1. Calculate the sum of numbers from 0 to n using the formula.
2. Calculate the sum of all elements in the array.
3. The difference between the expected sum and the array sum is the missing number.
*/

class Solution {
public:
    int missingNumber(vector<int>& nums) {
        int n = nums.size();

        int arr_sum = 0;
        int sum = n * (n + 1) / 2;

        for(int i = 0; i < n; i++) {
            arr_sum += nums[i];
        }

        return sum - arr_sum;
    }
};

