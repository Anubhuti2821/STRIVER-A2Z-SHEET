/*
Problem: Set Matrix Zeroes

Given an m x n matrix, if an element is 0, set its entire row
and column to 0 in-place.

Approach:
- Use the first row and first column as markers.
- Use an extra variable 'col' to keep track of whether the
  first column should be set to zero.
- Traverse the matrix twice:
  1. Mark the rows and columns that need to be zeroed.
  2. Update the remaining cells based on the markers.
- Finally, handle the first row and first column separately.

Time Complexity: O(n * m)
Space Complexity: O(1)
*/

class Solution {
public:
    void setZeroes(vector<vector<int>>& matrix) {

        int n = matrix.size();
        int m = matrix[0].size();

        int col = 1;

        // Mark rows and columns
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < m; j++) {

                if (matrix[i][j] == 0) {

                    matrix[i][0] = 0;

                    if (j != 0)
                        matrix[0][j] = 0;
                    else
                        col = 0;
                }
            }
        }

        // Set cells to zero based on markers
        for (int i = 1; i < n; i++) {
            for (int j = 1; j < m; j++) {

                if (matrix[i][0] == 0 || matrix[0][j] == 0)
                    matrix[i][j] = 0;
            }
        }

        // Handle first row
        if (matrix[0][0] == 0) {
            for (int j = 0; j < m; j++)
                matrix[0][j] = 0;
        }

        // Handle first column
        if (col == 0) {
            for (int i = 0; i < n; i++)
                matrix[i][0] = 0;
        }
    }
};

