/*
Problem: 2149. Rearrange Array Elements by Sign

Description:
Given an array nums containing an equal number of positive and negative
integers, rearrange the array such that:
- Every consecutive pair has opposite signs.
- The relative order of positive and negative numbers is preserved.
- The rearranged array starts with a positive integer.

Approach:
- Create an answer array of the same size as nums.
- Maintain two indices:
    - Even index (0, 2, 4, ...) for positive numbers.
    - Odd index (1, 3, 5, ...) for negative numbers.
- Traverse the input array once:
    - Place positive numbers at the current even index.
    - Place negative numbers at the current odd index.
    - Increment the corresponding index by 2.
*/

class Solution {
public:
    vector<int> rearrangeArray(vector<int>& nums) {
        int n = nums.size();
        vector<int> ans(n);

        int pos = 0;
        int neg = 1;

        for (int i = 0; i < n; i++) {
            if (nums[i] > 0) {
                ans[pos] = nums[i];
                pos += 2;
            } else {
                ans[neg] = nums[i];
                neg += 2;
            }
        }

        return ans;
    }
};

