/*
Problem: Leaders in an Array

Approach:
1. The last element is always a leader, so add it to the answer.
2. Traverse the array from right to left while maintaining the maximum element seen so far.
3. If the current element is greater than the maximum, it is a leader.
4. Update the maximum after processing each element.
5. Since leaders are collected from right to left, reverse the answer before returning.
*/

class Solution {
public:
    vector<int> leaders(vector<int>& nums) {
        vector<int> ans;

        int n = nums.size();
        int maximum = nums[n - 1];

        ans.push_back(nums[n - 1]);

        for(int i = n - 2; i >= 0; i--) {
            if(nums[i] > maximum) {
                ans.push_back(nums[i]);
            }

            maximum = max(maximum, nums[i]);
        }

        reverse(ans.begin(), ans.end());

        return ans;
    }
};

