/*
Problem: Set Matrix Zeroes

Description:
Given an m x n matrix, if an element is 0, set its entire row and
column to 0.

Approach:
- Traverse the matrix and store the rows and columns containing 0.
- Traverse the matrix again.
- If the current cell belongs to a marked row or column,
  set it to 0.
*/

class Solution {
public:
    void setZeroes(vector<vector<int>>& matrix) {
        int m = matrix.size();
        int n = matrix[0].size();

        vector<int> row(m, 0);
        vector<int> col(n, 0);

        // Mark the rows and columns containing 0
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                if (matrix[i][j] == 0) {
                    row[i] = 1;
                    col[j] = 1;
                }
            }
        }

        // Set the required cells to 0
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                if (row[i] == 1 || col[j] == 1) {
                    matrix[i][j] = 0;
                }
            }
        }
    }
};

/*
Time Complexity: O(m × n)
Space Complexity: O(m + n)

Possible Optimization:
The optimal solution uses the first row and first column of the matrix
as marker arrays, reducing the extra space complexity to O(1).
