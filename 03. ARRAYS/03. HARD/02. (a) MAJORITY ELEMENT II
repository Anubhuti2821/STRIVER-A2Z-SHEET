/*
Problem: Majority Element II

Description:
Given an integer array nums of size n, return all elements that appear
more than ⌊n / 3⌋ times.

Approach:
- Sort the array.
- Count the frequency of consecutive equal elements.
- If the frequency of an element becomes greater than n/3, store it in
  an unordered_set to avoid duplicates.
- Convert the set into a vector and return it.
*/

class Solution {
public:
    vector<int> majorityElement(vector<int>& nums) {
        unordered_set<int> s;
        int n = nums.size();

        sort(nums.begin(), nums.end());

        int count = 1;

        for (int i = 1; i < n; i++) {
            if (nums[i] == nums[i - 1]) {
                count++;
            } else {
                count = 1;
            }

            if (count > n / 3) {
                s.insert(nums[i]);
            }
        }

        return vector<int>(s.begin(), s.end());
    }
};

