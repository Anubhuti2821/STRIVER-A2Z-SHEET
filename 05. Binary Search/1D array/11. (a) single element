//incomplete can't solve
class Solution {
public:
    int singleNonDuplicate(vector<int>& nums) {
        int n = nums.size();
        int st = 0;
        int end = n-1;
        int mid ;
        int ans;
        while(st <= end){
             mid = st +((end-st)/2);
             if(mid == 0){
                 ans = 0;
                 break;
             }
            if(nums[mid - 1] != nums[mid] && nums[mid + 1] != nums[mid]){
              ans = mid;
              break;
             }
            if(mid % 2 == 0){
                if(nums[mid+1] == nums[mid]){
                    st = mid + 2;
                }
                else if(nums[mid - 1] == nums[mid]){
                    end = mid - 2;
       
                }
            }
            else{
                  if(nums[mid-1] == nums[mid]){
                    st = mid + 2 ;
                }
                else if(nums[mid + 1] != nums[mid]){
                    end = mid -2;
       
                }

            }
        }
        return nums[ans];
    }
};
