/*
Problem:
Given a sorted array where every element appears exactly twice except for one element
which appears only once, return that single element.

Approach:
Binary Search (Parity Based)
*/

class Solution {
public:
    int singleNonDuplicate(vector<int>& nums) {
        int n = nums.size();

        // Boundary Cases
        if (n == 1) return nums[0];
        if (nums[0] != nums[1]) return nums[0];
        if (nums[n - 1] != nums[n - 2]) return nums[n - 1];

        int st = 1;
        int end = n - 2;

        while (st <= end) {
            int mid = st + (end - st) / 2;

            // Found the single element
            if (nums[mid] != nums[mid - 1] &&
                nums[mid] != nums[mid + 1]) {
                return nums[mid];
            }

            // We are on the left side
            if ((mid % 2 == 1 && nums[mid] == nums[mid - 1]) ||
                (mid % 2 == 0 && nums[mid] == nums[mid + 1])) {
                st = mid + 1;
            }
            // We are on the right side
            else {
                end = mid - 1;
            }
        }

        return -1;
    }
};

/*
TIME COMPLEXITY: O(log n)
SPACE COMPLEXITY: O(1)

------------------------------------------------------
Mistakes I made while deriving this approach:

1. Didn't handle boundary cases.
   - n == 1
   - first element is unique
   - last element is unique

2. Search should start from:
      st = 1
      end = n - 2
   so that mid-1 and mid+1 are always valid.

3. I was skipping the pair using mid + 2 / mid - 2.
   In this invariant, only mid + 1 / mid - 1 is needed because
   binary search recalculates mid in every iteration.

4. I had two separate if-else blocks for even and odd indices.
   They can be merged into one condition:
      (odd && equal to left) ||
      (even && equal to right)

5. return nums[ans] / return mid was unnecessary.
   Return immediately when the single element is found.
*/
