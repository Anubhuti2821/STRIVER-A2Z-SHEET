/*
Problem: Find Square Root of a Number

Given a positive integer n, find and return its square root.
If n is not a perfect square, return the floor value of sqrt(n).

Example:
Input: n = 36
Output: 6

Input: n = 28
Output: 5
*/

class Solution {
public:
    int floorSqrt(int n) {
        int st = 0;
        int end = n;
        int ans = 0;

        while (st <= end) {
            int mid = st + (end - st) / 2;
            long long sq = 1LL * mid * mid;

            if (sq == n) {
                return mid;
            } else if (sq < n) {
                ans = mid;
                st = mid + 1;
            } else {
                end = mid - 1;
            }
        }

        return ans;
    }
};

/*
Time Complexity: O(log n)
Space Complexity: O(1)

Possible Optimization:
- Instead of computing 1LL * mid * mid, you can compare using
  mid <= n / mid to avoid multiplication overflow.
*/
