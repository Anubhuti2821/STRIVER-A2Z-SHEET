/*
Problem: Search X in a Sorted Array (Binary Search)

Approach:
1. Initialize two pointers:
   - st = 0
   - end = n - 1
2. Find the middle element.
3. If nums[mid] == target, return mid.
4. If nums[mid] > target, search in the left half.
5. Otherwise, search in the right half.
6. If the target is not found, return -1.

Time Complexity: O(log N)
Space Complexity: O(1)
*/

class Solution {
public:
    int search(vector<int>& nums, int target) {
        int st = 0;
        int end = nums.size() - 1;

        while (st <= end) {
            int mid = st + (end - st) / 2;

            if (nums[mid] == target) {
                return mid;
            }
            else if (nums[mid] > target) {
                end = mid - 1;
            }
            else {
                st = mid + 1;
            }
        }

        return -1;
    }
};

/*
Mistakes I Made While Learning:

1. Used:
   while(st >= end)
   Correct:
   while(st <= end)

2. Compared:
   if(mid == target)
   Correct:
   if(nums[mid] == target)
   (mid is an index, not the element.)

3. Used:
   end--;
   Correct:
   end = mid - 1;
   (Discard the entire right half.)

4. Used:
   st++;
   Correct:
   st = mid + 1;
   (Discard the entire left half.)

5. Confused index with value.
   Always compare the target with nums[mid], not with mid.

Key Binary Search Rule:
Left Search  -> end = mid - 1;
Right Search -> st = mid + 1;
*/

