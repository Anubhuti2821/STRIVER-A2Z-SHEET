/*
Problem: Koko Eating Bananas (LeetCode 875)

Question:
Koko loves to eat bananas. There are n piles of bananas, where the ith pile has piles[i] bananas.
The guards have gone and will come back in h hours.

Koko can decide her eating speed of k bananas per hour. Each hour, she chooses one pile and eats
up to k bananas from that pile. If the pile has fewer than k bananas, she eats all of them and
does not eat any more bananas during that hour.

Return the minimum integer k such that she can eat all the bananas within h hours.
*/

class Solution {
public:
    bool is_valid(vector<int>& piles, int h, int k) {
        long long hours = 0;

        for (int bananas : piles) {
            hours += bananas / k;
            if (bananas % k != 0) {
                hours++;
            }
        }

        return hours <= h;
    }

    int minEatingSpeed(vector<int>& piles, int h) {
        int st = 1;
        int end = *max_element(piles.begin(), piles.end());
        int ans = -1;

        while (st <= end) {
            int k = st + (end - st) / 2;

            if (is_valid(piles, h, k)) {
                ans = k;
                end = k - 1;
            } else {
                st = k + 1;
            }
        }

        return ans;
    }
};

/*
Time Complexity: O(n * log(max(piles)))

Space Complexity: O(1)

Possible Optimization:
Instead of:
    hours += bananas / k;
    if (bananas % k != 0) hours++;

Use ceiling division:
    hours += (bananas + k - 1) / k;

It is shorter and commonly used in interviews.
*/
